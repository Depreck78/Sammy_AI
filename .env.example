# Optional Sammy runtime configuration.
# Copy to .env only if you want to keep local shell settings in one place.
# The app does not load this file automatically; export values in your shell or service manager.

# Use 127.0.0.1 for local-only access, or 0.0.0.0 for same-Wi-Fi phone access.
# Network-reachable hosts expose Sammy's unauthenticated API. The CLI prompts before
# starting this way; set SAMMY_ALLOW_NETWORK=1 only for trusted automation.
SAMMY_HOST=127.0.0.1
SAMMY_PORT=3131
# SAMMY_ALLOW_NETWORK=0
SAMMY_HOME=~/.sammy
SAMMY_PUBLIC_URL=http://localhost:3131
SAMMY_OAUTH_REDIRECT_URI=http://localhost:3131/api/oauth/callback

# Local data paths. Keep these outside the repository.
# SAMMY_DB=~/.sammy/sammy.sqlite
# SAMMY_KEY=~/.sammy/sammy.key

# Ollama endpoint.
OLLAMA_URL=http://127.0.0.1:11434

# External Sammy plugin locations.
# SAMMY_PLUGIN_HOME=~/.sammy/plugins
# SAMMY_LOCAL_PLUGIN_HOME=~/plugins
# SAMMY_PLUGIN_PATHS=

# Optional compatibility import for an existing Codex plugin cache.
# Disabled by default; Sammy runs without Codex installed.
# SAMMY_INCLUDE_CODEX_CACHE=0
